# Chronoview web — environment variables
#
# Copy this file to .env for local dev. For Railway, paste the values
# (with your real values) into the web service's Raw Editor.
#
# At runtime in the container, entrypoint.sh substitutes these into
# /srv/config.js via envsubst, exposed to the SPA as window.__APP_CONFIG__.

# Backend API base URL.
# On Railway, reference the server service: https://${{server.RAILWAY_PUBLIC_DOMAIN}}
VITE_API_URL=http://localhost:8000

# Google sign-in (optional). Must match GOOGLE_CLIENT_ID on the server service.
VITE_GOOGLE_CLIENT_ID=

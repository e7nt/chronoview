# Chronoview web — production environment variables (Railway)
#
# Paste this block into the Railway `web` service:
#   Variables tab → Raw Editor → save
#
# The ${{...}} reference is Railway-specific and resolves at deploy time
# from the sibling `server` service. It will NOT expand in a regular .env
# file — use this only with Railway.
#
# These values are injected into the running container by entrypoint.sh
# via envsubst on /srv/config.template.js, then exposed to the SPA as
# window.__APP_CONFIG__.

# Backend API base URL.
VITE_API_URL=https://${{server.RAILWAY_PUBLIC_DOMAIN}}

# Google sign-in (optional). Must match GOOGLE_CLIENT_ID on the server service.
VITE_GOOGLE_CLIENT_ID=

# Chronoview server — environment variables
#
# Copy this file to .env for local dev. For Railway, paste the values
# (with your real secrets) into the server service's Raw Editor.

# Database — async (FastAPI/SQLAlchemy) and sync (Alembic) URLs.
# On Railway, reference the Postgres service:
#   DATABASE_URL=postgresql+asyncpg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
#   DATABASE_URL_SYNC=postgresql://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
DATABASE_URL=postgresql+asyncpg://timelines:timelines@db:5432/timelines
DATABASE_URL_SYNC=postgresql://timelines:timelines@db:5432/timelines

# JWT auth — REQUIRED in production. Generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# When true, unauthenticated requests fall back to a seeded "dev@localhost" user.
# MUST be false in any deployment.
DEV_MODE=true

# CORS — comma-separated origins of the frontend(s) that may call this API.
# On Railway, reference the web service: https://${{web.RAILWAY_PUBLIC_DOMAIN}}
CORS_ORIGINS=http://localhost:5173

# Google sign-in (optional). From Google Cloud Console → OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID=

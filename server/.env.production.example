# =============================================================================
# PRODUCTION ENVIRONMENT VARIABLES — Chronoview Backend (Railway)
# =============================================================================

# Database (Railway PostgreSQL — provided automatically via ${{Postgres.DATABASE_URL}})
DATABASE_URL=postgresql+asyncpg://postgres:password@host:5432/railway

# CORS (frontend URL on Railway)
CORS_ORIGINS=https://chronoview-web.up.railway.app

# Port (Railway sets this automatically)
PORT=8000

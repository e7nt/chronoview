# Chronoview server — production environment variables (Railway)
#
# Paste this block into the Railway `server` service:
#   Variables tab → Raw Editor → save
#
# The ${{...}} references are Railway-specific and resolve at deploy time
# from sibling services (Postgres, web). They will NOT expand in a regular
# .env file — use this only with Railway (or another platform that supports
# the same reference syntax).
#
# If your services aren't named exactly `Postgres` / `web`, edit the names
# in the references below to match what Railway shows in the sidebar.

DATABASE_URL=postgresql+asyncpg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
DATABASE_URL_SYNC=postgresql://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}

# JWT auth — generate a real value with: openssl rand -hex 32
# Never reuse a value that's been pasted in chat or committed anywhere.
SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Production: must be false. Disables the dev-user fallback in server/app/auth.py.
DEV_MODE=false

# CORS — frontend origin(s) allowed to call this API. Comma-separated.
CORS_ORIGINS=https://${{web.RAILWAY_PUBLIC_DOMAIN}}

# Google sign-in (optional). From Google Cloud Console → OAuth 2.0 Client IDs.
# Must match VITE_GOOGLE_CLIENT_ID on the web service.
GOOGLE_CLIENT_ID=

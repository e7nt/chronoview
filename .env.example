# Database
DATABASE_URL=postgresql+asyncpg://timelines:timelines@db:5432/timelines
DATABASE_URL_SYNC=postgresql://timelines:timelines@db:5432/timelines

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:5173

# JWT auth — REQUIRED in production. Generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local development convenience.
# When true, unauthenticated API requests fall through to a seeded "dev@localhost" user.
# MUST be false in any deployment. Default in code is false; opt in here for local dev.
DEV_MODE=true

# Google sign-in (optional). Get this from Google Cloud Console → OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID=

# Frontend
VITE_API_URL=http://localhost:8000

# Frontend Google sign-in (must match GOOGLE_CLIENT_ID above)
VITE_GOOGLE_CLIENT_ID=
